# Copia este archivo a .env y llena los valores. El archivo .env NUNCA se sube al repo.
#
# ── Cómo obtener estos valores ────────────────────────────────────────────────
#
# NOTION_TOKEN:
#   1. Ve a https://www.notion.so/my-integrations
#   2. Crea una nueva integración (ej: "OrganizadorDiplomacy")
#   3. Dale permiso de lectura a tu workspace
#   4. Copia el "Internal Integration Token" (empieza con "secret_...")
#
# NOTION_PLAYERS_DB_ID:
#   1. Abre tu base de datos de jugadores en Notion (en el navegador)
#   2. La URL se ve así:
#      https://www.notion.so/TU-WORKSPACE/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX?v=...
#      El ID es la cadena de 32 caracteres entre la última / y el ?
#   3. Pégalo tal cual (con o sin guiones, ambos funcionan)
#
#
# NOTION_PARTICIPACIONES_DB_ID:
#   1. Abre tu base de datos de Participaciones en Notion (en el navegador)
#   2. Extrae el ID de la URL igual que con NOTION_PLAYERS_DB_ID
#   3. Comparte también esta DB con tu integración (mismo proceso)
#   (Necesaria para filtrar partidas por año vía la propiedad 'Temporada')
#
# ─────────────────────────────────────────────────────────────────────────────

NOTION_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_PLAYERS_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_PARTICIPACIONES_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
API_PORT=5001